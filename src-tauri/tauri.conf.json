{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZUI",
  "version": "2.0.1",
  "identifier": "app.zui.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ZUI",
        "width": 440,
        "height": 700,
        "minWidth": 440,
        "minHeight": 700,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../resources/zapret": "resources/zapret"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "icons/zui_installer_head.bmp",
        "sidebarImage": "icons/zui_installer_sidebar.bmp",
        "uninstallerHeaderImage": "icons/zui_installer_head.bmp",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/zui.png",
      "icons/icon.ico"
    ]
  }
}
